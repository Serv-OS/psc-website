# ============================================================================
#  Peninsula Siding Company — environment variables
# ============================================================================

# ── Database ────────────────────────────────────────────────────────────────
# Local dev (SQLite, zero infra): a "file:" URI selects the SQLite adapter.
#   DATABASE_URI=file:./psc.db
# Production (Vercel Postgres / Neon): a Postgres URL selects the Postgres adapter.
#   DATABASE_URI=postgres://user:pass@host:5432/dbname?sslmode=require
DATABASE_URI=file:./psc.db

# ── Payload ─────────────────────────────────────────────────────────────────
# Long random string used to sign cookies / JWTs. Generate: openssl rand -hex 32
PAYLOAD_SECRET=change-me-to-a-long-random-string

# ── Site ────────────────────────────────────────────────────────────────────
# Public base URL — drives canonical tags, OG URLs, sitemap.xml, robots.txt.
NEXT_PUBLIC_SERVER_URL=https://www.peninsulasidingcompany.com

# Inbox that receives new-lead notification emails.
SALES_INBOX=info@peninsulasidingcompany.com

# ── Email (lead notifications) — optional ───────────────────────────────────
# Resend API key. If unset, leads still save but notification emails are skipped.
RESEND_API_KEY=
EMAIL_FROM="Peninsula Siding <info@peninsulasidingcompany.com>"

# ── Media storage ───────────────────────────────────────────────────────────
# Vercel Blob token. If unset, uploads are stored on the local filesystem (dev).
# In production this MUST be set — serverless filesystems are ephemeral.
BLOB_READ_WRITE_TOKEN=

# ── CRM (optional) ──────────────────────────────────────────────────────────
# HubSpot private-app token for optional lead sync.
HUBSPOT_TOKEN=
